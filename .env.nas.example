# Synology NAS — /volume1/docker/heavyjungle
# cp .env.nas.example .env 후 값 변경

POSTGRES_PASSWORD=change-me-to-strong-password

# ── MinIO (S3 호환 스토리지) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-to-strong-password

# ── Cloudflare Tunnel (권장) ──
# Zero Trust → Networks → Tunnels → 터널 선택 → Configure → Docker
# "cloudflared tunnel run --token eyJh..." 에서 eyJh... 부분만 복사
#
# Public hostname 예시:
#   heavyjungle.com      → http://app:3000
#   s3.heavyjungle.com   → http://minio:9000   (presigned PUT + 공개 읽기)
#
# S3_PUBLIC_URL은 브라우저 업로드(presigned PUT) 및 이미지 읽기용 HTTPS 주소입니다.
# docker compose build 시 NEXT_PUBLIC_S3_PUBLIC_URL에도 동일 값이 박힙니다 (재빌드 필요).
# Cloudflare Tunnel hostname과 일치해야 합니다.
S3_PUBLIC_URL=https://s3.heavyjungle.com/uploads

# ── App ──
APP_URL=https://heavyjungle.com

# ── Email (Resend) — 아이디/비밀번호 찾기 필수 ──
# https://resend.com 에서 API 키 발급, heavyjungle.com 도메인 인증 후 발신 주소 설정
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Heavy Jungle <noreply@heavyjungle.com>

# ── Admin (선택) ──
# ADMIN_USERNAMES=stansfield0125

# ── Umami 방문자 분석 (선택, 운영 DB와 별도 Postgres) ──
# docker-compose.nas.yml 의 umami / umami-db 서비스 참고
# Cloudflare Tunnel 예: analytics.heavyjungle.com → http://umami:3000
# UMAMI_DB_PASSWORD=change-me-umami-db
# UMAMI_APP_SECRET=change-me-umami-app-secret
# NEXT_PUBLIC_UMAMI_SRC=https://analytics.heavyjungle.com
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# UMAMI_API_URL=http://umami:3000
# UMAMI_API_TOKEN=
# 셀프호스팅은 API 키 없음 — 비워두고 로그인 방식(UMAMI_USERNAME/PASSWORD) 사용
# UMAMI_USERNAME=admin
# UMAMI_PASSWORD=
# UMAMI_WEBSITE_ID=

CLOUDFLARE_TUNNEL_TOKEN=
