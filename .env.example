# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heavyjungle

# Redis (cache / session / queue)
REDIS_URL=redis://localhost:6379

# Connection pool tuning for high-volume workloads
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10

# Cache TTL (seconds)
CACHE_TTL_SECONDS=300
