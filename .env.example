# App
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heavyjungle

# Redis (cache / session / queue)
REDIS_URL=redis://localhost:6379

# MinIO / S3 호환 스토리지 (로컬: docker compose up minio)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=uploads
S3_PUBLIC_URL=http://localhost:9000/uploads
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9000/uploads
S3_FORCE_PATH_STYLE=true

# App URL (비밀번호 재설정 링크 등)
APP_URL=http://localhost:3000

# Email (Resend) — 없으면 development에서 콘솔로 출력
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Heavy Jungle <noreply@heavyjungle.com>

# Admin — 쉼표 구분 username (DB role=admin 과 병행)
# ADMIN_USERNAMES=your_username

# Umami 방문자 분석 (선택) — 미설정 시 추적 스크립트·대시보드 방문자 섹션 생략
# NEXT_PUBLIC_UMAMI_SRC=https://analytics.heavyjungle.com
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-uuid
# UMAMI_API_URL=https://analytics.heavyjungle.com
# UMAMI_API_TOKEN=your-api-token
# 셀프호스팅 Umami(v3)는 API 키 UI가 없음 — 토큰 대신 관리자 로그인 사용
# UMAMI_USERNAME=admin
# UMAMI_PASSWORD=your-umami-password
# UMAMI_WEBSITE_ID=your-website-uuid

# Google Safe Browsing — 글·댓글 외부 링크 악성 검사 (선택, 서버 전용)
# https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
# GOOGLE_SAFE_BROWSING_API_KEY=your-api-key
