# App
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heavyjungle

# Redis (cache / session / queue)
REDIS_URL=redis://localhost:6379

# MinIO / S3 호환 스토리지 (로컬: docker compose up minio)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=uploads
S3_PUBLIC_URL=http://localhost:9000/uploads
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9000/uploads
S3_FORCE_PATH_STYLE=true

# App URL (비밀번호 재설정 링크 등)
APP_URL=http://localhost:3000

# Email (Resend) — 없으면 development에서 콘솔로 출력
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=배포는기도다 <onboarding@resend.dev>
